---
/**
 * Front gateway (Layer 3.1). Job: confirm credibility fast and route an
 * already-warm visitor to the right track. Not a persuasion page — a
 * confirmation-and-routing page. Centered/symmetric grid (2.3); two tracks at
 * EQUAL visual weight (6/6).
 *
 * Copy: the confirmed gateway headline and the two confirmed track names —
 * nothing else. About lives on its own page (/about) per review decision.
 */
import Base from '../layouts/Base.astro';
import RoutingTile from '../components/RoutingTile.astro';
import { TRACKS, TRACK_ORDER } from '../site.ts';
---

<Base
  title="Beacon Diagnostics"
  description="Beacon Diagnostics — Imaging Support Services and Cardiac Services."
  navVariant="gateway"
>
  <!-- Hero + routing: one navy panel continuing from the nav.
       Headline centered/symmetric (3.1); two tracks, equal 6/6. -->
  <section class="gateway-route panel-navy">
    <div class="grid-container">
      <div class="col gateway-route__head" style="--from:3;--to:11" data-reveal>
        <h1>Independent diagnostics. Straight answers.</h1>
      </div>
    </div>
    <div class="grid-container gateway-route__tiles">
      <div class="col" style="--from:1;--to:7" data-reveal>
        <RoutingTile
          href={TRACKS[TRACK_ORDER[0]].href}
          icon={TRACKS[TRACK_ORDER[0]].icon}
          title={TRACKS[TRACK_ORDER[0]].label}
        />
      </div>
      <div class="col" style="--from:7;--to:13" data-reveal>
        <RoutingTile
          href={TRACKS[TRACK_ORDER[1]].href}
          icon={TRACKS[TRACK_ORDER[1]].icon}
          title={TRACKS[TRACK_ORDER[1]].label}
        />
      </div>
    </div>
  </section>
</Base>

<style>
  .gateway-route { padding-block: var(--space-9); }
  .gateway-route__head {
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .gateway-route__tiles { row-gap: var(--gutter); }
</style>
