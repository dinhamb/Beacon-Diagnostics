---
/**
 * TEMPORARY holding page — the real site is intentionally taken dark so it
 * isn't publicly visible. Self-contained (no nav/footer, no external assets,
 * noindex) so nothing of the real site is exposed.
 *
 * TO RELAUNCH: revert the "Take site dark" commit (restores the real gateway,
 * imaging-qc, cardiac, and /qc-demo), then re-enable the push trigger in
 * .github/workflows/deploy.yml.
 */
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Beacon Diagnostics</title>
    <style>
      * { box-sizing: border-box; }
      html, body { height: 100%; }
      body {
        margin: 0;
        display: grid;
        place-items: center;
        min-height: 100vh;
        padding: 24px;
        text-align: center;
        background: radial-gradient(1200px 600px at 50% -10%, #12325f 0%, #0B2447 55%);
        color: #fff;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      }
      .mark { width: 88px; height: 88px; margin: 0 auto 24px; }
      h1 {
        font-family: Georgia, 'Times New Roman', serif;
        font-weight: 600;
        font-size: 27px;
        letter-spacing: 0.01em;
        margin: 0 0 10px;
      }
      .sub {
        font-size: 12px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #D4A017;
        margin: 0 0 22px;
      }
      p { color: #B5D4F4; font-size: 15px; line-height: 1.6; margin: 0; max-width: 30ch; }
    </style>
  </head>
  <body>
    <main>
      <svg class="mark" viewBox="0 0 64 64" fill="none" aria-hidden="true">
        <path d="M34 23 L60 14 L60 30 Z" fill="#D4A017" opacity="0.55" />
        <rect x="21" y="45.5" width="22" height="4.2" rx="1.4" fill="#fff" />
        <path d="M27.4 45.5 L36.6 45.5 L35 26 L29 26 Z" fill="#fff" />
        <path d="M28.7 38 L35.3 38 L35.05 35 L28.95 35 Z" fill="#0B2447" />
        <rect x="26.5" y="23.4" width="11" height="2.8" rx="0.8" fill="#fff" />
        <rect x="29" y="17.5" width="6" height="6" fill="#fff" />
        <path d="M27.6 17.5 L36.4 17.5 L32 11.5 Z" fill="#fff" />
        <circle cx="32" cy="10.4" r="1.3" fill="#D4A017" />
        <path d="M32 37.2 C31 35.4 28.2 35.6 28.2 37.9 C28.2 39.4 30.2 40.6 32 42 C33.8 40.6 35.8 39.4 35.8 37.9 C35.8 35.6 33 35.4 32 37.2 Z" fill="#C42E2E" />
      </svg>
      <h1>Beacon Diagnostics</h1>
      <div class="sub">Diagnostics &amp; quality assurance</div>
      <p>Our website is coming soon.</p>
    </main>
  </body>
</html>
