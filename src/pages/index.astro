---
/**
 * Front gateway (Layer 3.1). Job: confirm credibility fast and route an
 * already-warm visitor to the right track. Not a persuasion page — a
 * confirmation-and-routing page. Centered/symmetric grid (2.3); three tracks
 * at EQUAL visual weight (4/4/4 — still symmetric quarters of the 12-col
 * grid, per the equal-weight routing rule).
 *
 * Copy: the confirmed gateway headline and the confirmed track names —
 * nothing else. About lives on its own page (/about) per review decision.
 */
import Base from '../layouts/Base.astro';
import RoutingTile from '../components/RoutingTile.astro';
import { TRACKS, TRACK_ORDER } from '../site.ts';
---

<Base
  title="Beacon Diagnostics"
  description="Beacon Diagnostics — Imaging Support Services, Cardiac Services and Facility Design Consulting."
  navVariant="gateway"
  flushFooter
>
  <!-- Hero + routing: one navy panel continuing from the nav.
       Headline centered/symmetric (3.1); three tracks, equal 4/4/4. -->
  <section class="gateway-route panel-navy">
    <div class="grid-container">
      <div class="col gateway-route__head" style="--from:3;--to:11" data-reveal>
        <h1>Clear insight, better outcomes</h1>
      </div>
    </div>
    <div class="grid-container gateway-route__tiles">
      {TRACK_ORDER.map((id, i) => (
        <div class="col" style={`--from:${1 + i * 4};--to:${5 + i * 4}`} data-reveal>
          <RoutingTile href={TRACKS[id].href} icon={TRACKS[id].icon} title={TRACKS[id].label} />
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  /* The gateway is this page's only section: grow it to fill main so no
     body-colour strip is orphaned between it and the (flush) footer.
     :global(main) is safe — this stylesheet only loads on this page. */
  :global(main) {
    display: flex;
    flex-direction: column;
  }
  .gateway-route {
    padding-block: var(--space-9);
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .gateway-route__head {
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .gateway-route__tiles { row-gap: var(--gutter); }
</style>
