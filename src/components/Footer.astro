---
/**
 * Footer — rebuilt to the visual reference's exact spec (Layer 3.4 / 4.3):
 * navy panel, four columns 1.3fr/1fr/1fr/1fr with 24px gap, hairline rules.
 *
 *   1. logo ONLY — no tagline/brand statement, on purpose (3.4: "exactly the
 *      kind of unspecified slot that gets filled with generic marketing
 *      language by default")
 *   2. services   3. company (About page / Contact)
 *   4. trust-proof slot — RESERVED ON PURPOSE: present and visibly empty
 *      pre-launch rather than absent (4.3). No placeholder testimonials.
 *
 * Bottom: contact line with the 1300 ALL HRT mnemonic kept visible (3.6.4 —
 * real information, not decoration; also on the tel link's title per review),
 * then copyright + privacy/terms.
 *
 * Exact reference values: column titles 10px #5F8AC2 uppercase ls 0.03em ·
 * links 11px #B5D4F4 lh 1.8 · bottom rows 10px #5F8AC2 · hairlines 0.5px
 * #1A3A5C · grid padding 28px/18px, bottom padding 14px.
 */
import Logo from './Logo.astro';
import Email from './Email.astro';
import { SITE, TRACKS, TRACK_ORDER, withBase } from '../site.ts';
const year = new Date().getFullYear();
const telHref = `tel:${SITE.phone.replace(/\s/g, '')}`;
---

<footer class="footer" id="contact">
  <div class="footer__inner">
    <div class="footer__grid">
      <!-- 1. logo only (3.4) -->
      <div class="footer__brand">
        <Logo background="dark" size={24} />
      </div>

      <!-- 2. services -->
      <nav class="footer__col" aria-label="Services">
        <h2 class="footer__title">services</h2>
        <ul class="footer__list">
          {TRACK_ORDER.map((id) => (
            <li><a class="footer__link" href={TRACKS[id].href}>{TRACKS[id].label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- 3. company -->
      <nav class="footer__col" aria-label="Company">
        <h2 class="footer__title">company</h2>
        <ul class="footer__list">
          <li><a class="footer__link" href={withBase('/about')}>About</a></li>
          <li><Email class="footer__link" label="Contact" /></li>
        </ul>
      </nav>

      <!-- 4. trust-proof slot: the grid keeps its four-column shape, but the
           column renders nothing until real pilot-site content exists (review
           decision — no placeholder text at all). -->
    </div>

    <div class="footer__bottom">
      <span>
        <Email class="footer__bottom-link" />
        &nbsp;&middot;&nbsp;
        <!-- number by default; crossfades to the 1300 ALL HRT mnemonic on
             hover/focus (review decision). Both forms exposed to AT. -->
        <a
          class="footer__bottom-link footer__phone"
          href={telHref}
          aria-label={`${SITE.phone} (${SITE.phoneMnemonic})`}
        >
          <span class="footer__phone-num" aria-hidden="true">{SITE.phone}</span>
          <span class="footer__phone-mn" aria-hidden="true">{SITE.phoneMnemonic}</span>
        </a>
      </span>
      <div class="footer__legal">
        <span>&copy; {year} beacon diagnostics</span>
        <span>
          <a class="footer__bottom-link" href={withBase('/privacy')}>privacy</a>
          &middot;
          <a class="footer__bottom-link" href={withBase('/terms')}>terms</a>
        </span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-navy);
    margin-top: var(--space-9);
  }
  /* Inner width tracks the site grid so footer content aligns with the pages. */
  .footer__inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-pad);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr 1fr; /* exact reference ratio */
    gap: 24px;
    padding-block: 28px 18px;
    border-bottom: 0.5px solid var(--color-navy-hairline);
  }

  .footer__title {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 400;
    color: var(--color-on-navy-faint);
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1.4;
  }
  .footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  /* :global — the Contact link is rendered by <Email> via set:html, which
     doesn't receive Astro's scoped-style attribute. */
  :global(.footer__link) {
    font-size: 11px;
    color: var(--color-on-navy);
    line-height: 1.8;
    text-decoration: none;
    transition: color var(--dur-press) var(--ease-resolve);
  }
  :global(.footer__link:hover) { color: #fff; }
  .footer__reserved {
    font-size: 11px;
    color: var(--color-on-navy-faint);
    font-style: italic;
    line-height: 1.8;
    margin: 0;
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    padding-block: 14px;
    font-size: 10px;
    color: var(--color-on-navy-faint);
  }
  .footer__legal {
    display: flex;
    justify-content: space-between;
    width: 100%;
  }
  /* :global — the email is rendered by <Email> via set:html (see .footer__link). */
  :global(.footer__bottom-link) {
    color: inherit;
    text-decoration: none;
    transition: color var(--dur-press) var(--ease-resolve);
  }
  :global(.footer__bottom-link:hover) { color: var(--color-on-navy); }

  /* Phone crossfade: both forms share one grid cell so the link keeps the
     width of the longer one — no layout shift on hover. */
  .footer__phone {
    display: inline-grid;
    text-align: left;
  }
  .footer__phone > span {
    grid-area: 1 / 1;
    transition: opacity 150ms var(--ease-resolve);
  }
  .footer__phone-mn { opacity: 0; }
  .footer__phone:hover .footer__phone-num,
  .footer__phone:focus-visible .footer__phone-num { opacity: 0; }
  .footer__phone:hover .footer__phone-mn,
  .footer__phone:focus-visible .footer__phone-mn { opacity: 1; }

  @media (max-width: 880px) {
    .footer__inner { padding-inline: var(--grid-pad-mobile); }
    .footer__grid { grid-template-columns: 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 480px) {
    .footer__grid { grid-template-columns: 1fr; }
  }
</style>
