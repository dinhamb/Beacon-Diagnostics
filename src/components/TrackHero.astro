---
/**
 * TrackHero — service-page hero built to the visual reference's exact spec.
 *
 * Layout (exact reference values): content:visual = 1.1fr : 0.9fr · content
 * padding 40px block (container supplies the left margin) · H1 → sub gap 14px
 * · sub → CTA gap 16px · cred line 12px #5F8AC2 with 24px below · visual side
 * on the deep panel (#082038) with the track's calibration motif SVG copied
 * verbatim from the reference.
 *
 * NO stats row, NO methodology teaser — deliberate (reference annotation +
 * 3.6 minimal-content decision). A stats row returns only with real figures.
 * The CTA is the mock's spec (deep amber fill, white text, 11px/22px padding,
 * 14px/500): "one primary CTA only, never two competing amber buttons" (3.2).
 */
import { SITE } from '../site.ts';

interface Props {
  variant: 'imaging' | 'cardiac';
  sub: string;
  cred?: string;
}
const { variant, sub, cred } = Astro.props;
const contactHref = `mailto:${SITE.email}`;
---

<section class="hero panel-navy">
  <div class="hero__inner">
    <div class="hero__grid">
      <div class="hero__content" data-reveal>
        <h1 class="hero__h1"><slot /></h1>
        <p class="hero__sub" set:html={sub} />
        {cred && <p class="hero__cred">{cred}</p>}
        <a class="hero__cta" href={contactHref}>Get in touch</a>
      </div>

      <div class="hero__visual" aria-hidden="true">
        {variant === 'imaging' ? (
          <svg width="100%" height="100%" viewBox="0 0 320 300" class="hero__motif">
            <g opacity="0.5">
              <circle cx="60" cy="60" r="2.5" fill="#3D5A80"/><circle cx="90" cy="40" r="2.5" fill="#3D5A80"/>
              <circle cx="220" cy="50" r="2.5" fill="#3D5A80"/><circle cx="260" cy="85" r="2.5" fill="#3D5A80"/>
              <circle cx="55" cy="250" r="2.5" fill="#3D5A80"/><circle cx="240" cy="240" r="2.5" fill="#3D5A80"/>
            </g>
            <rect x="60" y="120" width="200" height="65" fill="none" stroke="#D4A017" stroke-width="1" rx="4" opacity="0.9"/>
            <circle cx="80" cy="140" r="3" fill="#D4A017"/><circle cx="120" cy="155" r="3" fill="#D4A017"/>
            <circle cx="160" cy="145" r="3" fill="#D4A017"/><circle cx="200" cy="165" r="3" fill="#D4A017"/><circle cx="240" cy="150" r="3" fill="#D4A017"/>
            <line x1="80" y1="140" x2="120" y2="155" stroke="#D4A017" stroke-width="1" opacity="0.6"/>
            <line x1="120" y1="155" x2="160" y2="145" stroke="#D4A017" stroke-width="1" opacity="0.6"/>
            <line x1="160" y1="145" x2="200" y2="165" stroke="#D4A017" stroke-width="1" opacity="0.6"/>
            <line x1="200" y1="165" x2="240" y2="150" stroke="#D4A017" stroke-width="1" opacity="0.6"/>
            <text x="80" y="205" font-size="10" fill="#85B7EB">within tolerance</text>
          </svg>
        ) : (
          <svg width="100%" height="100%" viewBox="0 0 320 300" class="hero__motif">
            <g opacity="0.5">
              <circle cx="70" cy="55" r="2.5" fill="#3D5A80"/><circle cx="100" cy="85" r="2.5" fill="#3D5A80"/>
              <circle cx="220" cy="45" r="2.5" fill="#3D5A80"/><circle cx="250" cy="95" r="2.5" fill="#3D5A80"/>
              <circle cx="60" cy="235" r="2.5" fill="#3D5A80"/><circle cx="230" cy="225" r="2.5" fill="#3D5A80"/>
            </g>
            <rect x="70" y="130" width="180" height="55" fill="none" stroke="#D4A017" stroke-width="1" rx="4" opacity="0.9"/>
            <circle cx="90" cy="148" r="3" fill="#D4A017"/><circle cx="130" cy="158" r="3" fill="#D4A017"/>
            <circle cx="170" cy="145" r="3" fill="#D4A017"/><circle cx="210" cy="163" r="3" fill="#D4A017"/><circle cx="240" cy="150" r="3" fill="#D4A017"/>
            <line x1="90" y1="148" x2="130" y2="158" stroke="#D4A017" stroke-width="1" opacity="0.6"/>
            <line x1="130" y1="158" x2="170" y2="145" stroke="#D4A017" stroke-width="1" opacity="0.6"/>
            <line x1="170" y1="145" x2="210" y2="163" stroke="#D4A017" stroke-width="1" opacity="0.6"/>
            <line x1="210" y1="163" x2="240" y2="150" stroke="#D4A017" stroke-width="1" opacity="0.6"/>
            <text x="90" y="205" font-size="10" fill="#85B7EB">clarity, resolved</text>
          </svg>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  /* Inner width tracks the site grid so hero content aligns with the pages. */
  .hero__inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-pad);
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr; /* exact reference ratio (~55/45) */
    min-height: 400px;
  }
  .hero__content {
    padding-block: 40px; /* exact reference value */
    padding-right: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  .hero__h1 {
    color: #fff;
    margin-bottom: 14px; /* exact reference gap H1 -> sub */
  }
  .hero__sub {
    font-family: var(--font-body);
    font-size: 15px; /* reference .sub treatment */
    color: var(--color-on-navy);
    line-height: 1.6;
    max-width: 360px; /* exact reference value */
    margin-bottom: 16px; /* exact reference gap sub -> CTA */
  }
  .hero__cred {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-on-navy-faint);
    line-height: 1.6;
    max-width: 360px;
    margin-bottom: 24px; /* exact reference value */
  }

  /* CTA — mock spec: deep amber fill + white text (accessible pair), one per
     section, plain label, no icon. */
  .hero__cta {
    background: var(--color-amber-deep);
    color: #fff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.02em;
    line-height: 1;
    padding: 11px 22px;
    border-radius: 6px;
    text-decoration: none;
    transition: background-color var(--dur-press) var(--ease-resolve),
      transform var(--dur-press) var(--ease-resolve);
  }
  .hero__cta:hover { background: #855e0b; } /* a shade darker, stays > AA with white */
  .hero__cta:active { transform: scale(0.98); } /* press state per 4.2 */

  .hero__visual {
    position: relative;
    background: var(--color-navy-deep);
  }
  .hero__motif {
    position: absolute;
    inset: 0;
  }

  @media (max-width: 880px) {
    .hero__inner { padding-inline: var(--grid-pad-mobile); }
    .hero__grid { grid-template-columns: 1fr; min-height: 0; }
    .hero__content { padding: 40px 0; }
    .hero__visual { height: 240px; margin-bottom: 40px; }
  }
</style>
