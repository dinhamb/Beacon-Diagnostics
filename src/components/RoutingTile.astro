---
/**
 * RoutingTile — a gateway routing card (Layer 3.1). The two tracks are presented
 * with EQUAL visual weight; neither subordinate. Identical structure, identical
 * emphasis — asymmetry here would undercut the routing logic itself.
 *
 * Bare track name only — no blurb/descriptive copy until exact wording is
 * confirmed (3.6 has none). Sits on the navy panel: deep-panel fill (#082038)
 * with the navy hairline, track icon as a thin bright-amber mark (2.1/2.4).
 * The whole card is the target; the arrow nudges on hover (restraint, 4.2).
 */
import Icon from './Icon.astro';

interface Props {
  href: string;
  icon: string;
  title: string;
}
const { href, icon, title } = Astro.props;
---

<a class="tile" href={href}>
  <span class="tile__icon" aria-hidden="true">
    <Icon name={icon as any} size={26} stroke={1.5} />
  </span>
  <h2 class="tile__title">{title}</h2>
  <Icon name="arrow-right" size={18} stroke={1.75} class="tile__arrow" />
</a>

<style>
  .tile {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-6) var(--space-6);
    min-height: 108px;
    background: var(--color-navy-deep);
    border: 0.5px solid var(--color-navy-hairline);
    border-radius: var(--radius);
    text-decoration: none;
    transition: border-color var(--dur-press) var(--ease-resolve),
      transform var(--dur-press) var(--ease-resolve);
  }
  .tile:hover { border-color: var(--color-slate); }
  .tile:active { transform: scale(0.98); } /* press state per 4.2 */

  .tile__icon {
    display: inline-flex;
    flex: none;
    color: var(--color-amber); /* thin bright-amber mark on navy (2.1) */
  }
  .tile__title {
    font-size: var(--fs-h3);
    color: #fff;
    margin: 0;
    flex: 1;
  }
  :global(.tile__arrow) { flex: none; }
  .tile > :global(.tile__arrow) {
    color: var(--color-on-navy);
    transition: transform var(--dur-press) var(--ease-resolve);
  }
  .tile:hover > :global(.tile__arrow) { transform: translateX(3px); }
</style>
