---
/**
 * TrackBadge — orientation for a visitor already inside a track (Layer 3.4),
 * rebuilt to the visual reference's .badge spec: amber pill on navy, sitting
 * beside the brand in the navbar.
 *
 * Exact values from the reference file:
 *   10px bright-amber text · rgba(212,160,23,0.1) fill · 4px/10px padding ·
 *   999px radius · lowercase label (matches the mock's rendering)
 */
import Icon from './Icon.astro';

interface Props {
  icon: string;
  label: string;
}
const { icon, label } = Astro.props;
---

<span class="track-badge">
  <Icon name={icon as any} size={12} stroke={1.75} class="track-badge__icon" />
  <span>{label}</span>
</span>

<style>
  .track-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--color-amber-10);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.01em;
    text-transform: lowercase;
    color: var(--color-amber); /* bright amber on navy (2.1) */
    line-height: 1.4;
    white-space: nowrap;
  }
  .track-badge__icon { flex: none; }
</style>
