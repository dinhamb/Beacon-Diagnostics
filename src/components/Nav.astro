---
/**
 * Navigation — condensed into a single menu disclosure at all widths (owner
 * request: condense the header links into a hamburger/dropdown).
 *
 * Built on a native <details>/<summary> disclosure so it opens and closes
 * WITHOUT JavaScript — progressive enhancement (Layer 4.4). The small script
 * only adds niceties (close on Escape, outside-click, and link-choice); with
 * JS off, the browser's native disclosure still works and every link stays
 * reachable.
 *
 * Bar: brand (logo + active-track badge on service pages) on the left, the
 * menu on the right. The menu holds the track links, an "All services" link
 * on service pages, and Contact. Sticky — the ONE sticky element (4.1).
 *
 * Note: this condenses the equal-weight track links behind a menu, a
 * deliberate divergence from 3.4's always-visible nav arms (owner request).
 */
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import Email from './Email.astro';
import TrackBadge from './TrackBadge.astro';
import { TRACKS, TRACK_ORDER, withBase, type TrackId } from '../site.ts';

interface Props {
  variant?: 'gateway' | 'service';
  active?: TrackId;
}
const { variant = 'gateway', active } = Astro.props;
const current = active ? TRACKS[active] : null;
const home = withBase('/');
---

<header class="nav" data-nav>
  <div class="nav__bar">
    <div class="nav__brand">
      <Logo background="dark" size={28} />
      {variant === 'service' && current && (
        <TrackBadge icon={current.icon} label={current.label} />
      )}
    </div>

    <!-- Native disclosure: works with JS disabled. -->
    <details class="nav__menu" data-nav-menu>
      <summary class="nav__summary" aria-label="Menu">
        <span class="nav__summary-open"><Icon name="menu" size={24} /></span>
        <span class="nav__summary-close"><Icon name="close" size={24} /></span>
      </summary>

      <nav class="nav__panel" aria-label="Primary">
        {TRACK_ORDER.map((id) => (
          <a class="nav__panel-link" href={TRACKS[id].href}>{TRACKS[id].navLabel}</a>
        ))}
        {variant === 'service' && (
          <a class="nav__panel-link nav__panel-link--muted" href={home}>All services</a>
        )}
        <Email class="nav__panel-link nav__panel-link--contact" label="Contact" withIcon />
      </nav>
    </details>
  </div>
</header>

<style>
  /* The bar is the top segment of the navy panel (reference: .navbar.bordered).
     Sticky — the ONE sticky element on the page (4.1). */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-navy);
    border-bottom: 0.5px solid var(--color-navy-hairline);
  }
  .nav__bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 28px; /* exact reference value */
    gap: var(--space-5);
  }

  /* brand group — badge sits beside the logo, gap 14px (reference) */
  .nav__brand {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  /* ---- disclosure menu ---- */
  .nav__menu {
    position: relative;
  }

  /* Summary = the hamburger button. Strip the native marker. */
  .nav__summary {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem;
    cursor: pointer;
    color: #fff;
    list-style: none;
    border-radius: var(--radius-sm);
    transition: color var(--dur-press) var(--ease-resolve);
  }
  .nav__summary::-webkit-details-marker { display: none; }
  .nav__summary:hover { color: var(--color-on-navy); }
  .nav__summary-open,
  .nav__summary-close { display: inline-flex; }
  .nav__summary-close { display: none; }
  .nav__menu[open] .nav__summary-open { display: none; }
  .nav__menu[open] .nav__summary-close { display: inline-flex; }

  /* Panel = a compact dropdown card, right-anchored under the hamburger,
     overlaying content (absolute) rather than pushing it down. */
  .nav__panel {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    min-width: 220px;
    display: flex;
    flex-direction: column;
    padding: var(--space-2);
    background: var(--color-navy);
    border: 0.5px solid var(--color-navy-hairline);
    border-radius: var(--radius);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
  }
  /* :global — the Contact item is rendered by <Email> via set:html, which
     doesn't receive Astro's scoped-style attribute; global rules reach it
     (and the in-template track links match too, harmlessly). */
  :global(.nav__panel-link) {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.625rem 0.75rem;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-on-navy);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color var(--dur-press) var(--ease-resolve),
      background-color var(--dur-press) var(--ease-resolve);
  }
  :global(.nav__panel-link:hover) {
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
  }
  :global(.nav__panel-link--muted) { color: var(--color-on-navy-faint); }
  /* Contact — the one distinct item ("one accent, one job"), set off by a
     hairline above it. */
  :global(.nav__panel-link--contact) {
    margin-top: var(--space-2);
    padding-top: 0.75rem;
    color: #fff;
    font-weight: var(--weight-medium);
    border-top: 0.5px solid var(--color-navy-hairline);
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
  }

  @media (max-width: 880px) {
    .nav__bar { padding: 14px 20px; } /* mobile side margin (2.3) */
  }
</style>

<script>
  // Progressive enhancement only — the <details> menu already opens/closes
  // natively without this. Here we add: close on Escape, close when clicking
  // outside, and close after choosing a link (needed because view transitions
  // swap the DOM without a full reload). Bound once at document level and
  // guarded, so it survives astro:page-load re-runs.
  function initNav() {
    if ((document as any).__navBound) return;
    (document as any).__navBound = true;

    const currentMenu = () =>
      document.querySelector<HTMLDetailsElement>('[data-nav-menu][open]');

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const menu = currentMenu();
        if (menu) menu.open = false;
      }
    });

    document.addEventListener('click', (e) => {
      const menu = currentMenu();
      if (!menu) return;
      const target = e.target as HTMLElement;
      // Close when a link inside the panel is chosen…
      if (target.closest('.nav__panel a')) {
        menu.open = false;
        return;
      }
      // …or when the click lands outside the menu entirely.
      if (!target.closest('[data-nav-menu]')) menu.open = false;
    });
  }
  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>
